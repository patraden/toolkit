# Template of environment variables understood by the Makefile and by
# docker-compose.yml when invoked directly (i.e. without `make`).
#
# IMPORTANT: This file is NOT auto-loaded anywhere. The Makefile invokes
# `docker compose --env-file /dev/null`, and Compose's own `.env` auto-load
# only fires for files literally named `.env` at the project root. This file
# exists as (a) reference documentation of every knob and (b) an optional
# `source`-able helper. To use: `source ./.env.example && make compose-up`.

# --- required if you run `docker compose` directly ---------------------------
# The Makefile auto-detects the Vertica RPM from packages/vertica*.rpm, so
# under `make` this is optional. Uncomment and set it when: you invoke
# `docker compose build` directly, or multiple RPMs coexist in packages/ and
# you want to pin one.
# export VERTICA_PACKAGE=vertica-<version>-<release>.x86_64.RHEL6.rpm

# --- image identity (defaults match the Makefile) ----------------------------
export IMAGE_NODE_NAME=vertica-ce-node
export TAG=latest
# VERTICA_NODE_IMAGE is always re-derived by the Makefile as
# $(IMAGE_NODE_NAME):$(TAG); the shell-level export below only affects
# `docker compose` invocations that bypass the Makefile.
export VERTICA_NODE_IMAGE="${IMAGE_NODE_NAME}:${TAG}"

# --- base OS (forwarded as build args) ---------------------------------------
export OS_IMAGE=almalinux
export OS_VERSION=8.10

# --- database identity -------------------------------------------------------
# Changing VERTICA_DB_NAME after a cluster has been initialised requires
# `make clean` to drop the /data volumes (the persisted admintools.conf,
# catalog/data dirs and dbadmin SSH keys still reference the old name).
export VERTICA_DB_NAME=dockerdb

# dbadmin user/group identity baked into the image (build args). Override
# only if you need to match a specific host UID/GID; changing any of these
# requires a rebuild and, for an initialised cluster, `make clean`.
# export VERTICA_DB_USER=dbadmin
# export VERTICA_DB_GROUP=verticadba
# export VERTICA_DB_UID=1000
# export VERTICA_DB_GID=1000

# --- host port mappings (defaults shown; consumed by docker-compose.yml) -----
# export VERTICA1_DB_PORT=54331
# export VERTICA1_SSH_PORT=10022
# export VERTICA2_DB_PORT=54332
# export VERTICA2_SSH_PORT=10023
# export VERTICA3_DB_PORT=54333
# export VERTICA3_SSH_PORT=10024
