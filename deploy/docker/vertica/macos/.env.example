# Template of environment variables understood by the Makefile.
#
# IMPORTANT: This file is NOT auto-loaded by the Makefile nor by docker-compose
# (the Makefile invokes `docker compose --env-file /dev/null`). It exists only
# as a reference and as an optional `source`-able helper. 

# Required: must match the RPM filename under packages/
export VERTICA_PACKAGE=vertica-11.0.0-3.x86_64.RHEL6.rpm

# Image name + tag (derived). Keep these two lines in order so the third
# expands correctly; 
export IMAGE_NODE_NAME=vertica-ce-node
export TAG=11.0.0-3
export VERTICA_NODE_IMAGE="${IMAGE_NODE_NAME}:${TAG}"

# Match Makefile OS (also forwarded to compose build args)
export OS_IMAGE=almalinux
export OS_VERSION=8.10

# Database name used by the entrypoint for auto start_db / stop_db.
# Must match the -d value you pass to `make create-db` (default dockerdb).
export VERTICA_DB_NAME=dockerdb

# dbadmin user/group identity baked into the image (build args). Override only
# if you need to match a specific host UID/GID. Changing these requires
# rebuilding the image (`make docker-build-node`).
# export VERTICA_DB_USER=dbadmin
# export VERTICA_DB_GROUP=verticadba
# export VERTICA_DB_UID=1000
# export VERTICA_DB_GID=1000

# Host port mappings (defaults shown; consumed by docker-compose.yml).
# export VERTICA1_DB_PORT=54331
# export VERTICA1_SSH_PORT=10022
# export VERTICA2_DB_PORT=54332
# export VERTICA2_SSH_PORT=10023
# export VERTICA3_DB_PORT=54333
# export VERTICA3_SSH_PORT=10024
#
# Compose adds cap_add AUDIT_WRITE and SYS_NICE per service (see
# docker-compose.yml) for install_vertica / dbadmin su + ssh-keygen.
